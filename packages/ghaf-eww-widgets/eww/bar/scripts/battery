#!/run/current-system/sw/bin/sh

bat=/sys/class/power_supply/BAT0/
per="$(cat "$bat/capacity")"

icon() {

	[ $(cat "$bat/status") = Charging ] && echo "оЂЉ" && exit

	if [ "$per" -gt "90" ]; then
		icon="п•ё"
	elif [ "$per" -gt "80" ]; then
		icon="п–Ѓ"
	elif [ "$per" -gt "70" ]; then
		icon="п–Ђ"
	elif [ "$per" -gt "60" ]; then
		icon="п•ї"
	elif [ "$per" -gt "50" ]; then
		icon="п•ѕ"
	elif [ "$per" -gt "40" ]; then
		icon="п•Ѕ"
	elif [ "$per" -gt "30" ]; then
		icon="п•ј"
	elif [ "$per" -gt "20" ]; then
		icon="п•»"
	elif [ "$per" -gt "10" ]; then
		icon="п•»"
		notify-send -u critical "Battery Low" "Connect Charger"
	elif [ "$per" -gt "0" ]; then
		icon="п•є"
		notify-send -u critical "Battery Low" "Connect Charger"
	else
		echo п–Ќ && exit
	fi
	echo "$icon"
}

percent() {
	echo $per
}

[ "$1" = "icon" ] && icon && exit
[ "$1" = "percent" ] && percent && exit
exit
